# Anime Manager Configuration
# Copy this file to .env and customize the values

# ===========================================
# PATHS - Auto-detected based on OS:
#   - Termux (Android): /data/data/com.termux/files/home/storage/shared/Anime
#   - Windows: C:\Users\Omain\Anime
#   - Linux: /mnt/MySSD/Users/Omain/Anime/
# ===========================================
# Override auto-detection (uncomment and set your path):
# ANIME_DIR=/custom/path/to/anime

# AniList API Token (optional - for syncing progress)
# Leave empty to disable AniList features
ANILIST_TOKEN=

# AniList username for fetching your anime list
ANILIST_USERNAME=

# Flask configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# Download settings
MAX_CONCURRENT_DOWNLOADS=3
DOWNLOAD_CHUNK_SIZE=1048576

# Cloudflare bypass mode:
#   - cloudscraper : Automated bypass using cloudscraper library (recommended)
#   - selenium     : Uses undetected-chromedriver (requires Chrome)
#   - manual       : Requires manual cookie entry
CLOUDFLARE_MODE=cloudscraper

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
